  <property name="styleSheet">
   <string notr="true">QDialog {    	
	background-color: rgb(240, 242, 245);
}

QLineEdit#leUsername,
QLineEdit#lePassword {
	border-top: none;
    border-right: none;
    border-left: none;
    border-bottom: 2px solid #cccccc;
    background: transparent;
    padding: 8px 0;
	font: 12pt &quot;Segoe UI&quot;;
}

QLineEdit#leUsername:hover,
QLineEdit#lePassword:hover {
	border-bottom-color: #4986cc;
}

QLineEdit#leUsername:focus,
QLineEdit#lePassword:focus {
    border-bottom: 4px solid #3a7bc8;
    padding-bottom: 7px; 
}

QLabel#lblUsername,
QLabel#lblPassword {
	font: 700 10pt &quot;Segoe UI&quot;;
}

QPushButton#btnSignIn {
	background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, 
                                stop:1 #764ba2);
    border: none;
    border-radius: 8px;
    color: white;
    font-size: 18px;
    font-weight: bold;
    padding: 16px 32px;
    text-transform: uppercase;
    letter-spacing: 1px;
	margin-top: 20px;
	margin-bottom: 10px;
}

QPushButton#btnSignIn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #5a6fd8, 
                                stop:1 #6a4190);
}

QPushButton#btnSignIn:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #4a5ec6, 
                                stop:1 #5a3780);
    padding: 17px 32px 15px 32px;
}

QPushButton#btnSignIn:disabled {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #cccccc, 
                                stop:1 #aaaaaa);
    color: #666666;
}

QWidget#switchButtonsContainer {
    background: white;
    border-radius: 8px 8px 0 0;
    padding: 0;
    margin: 0;
}

QPushButton#btnSignInPage, 
QPushButton#btnSignUpPage {
    background: white;
    border: none;
    border-radius: 8px 8px 0 0;
    color: #626d7a;
    font-size: 16px;
    font-weight: 600;
    padding: 15px;
    margin: 0;
    min-width: 120px;
    position: relative;
}

QPushButton#btnSignInPage:checked, 
QPushButton#btnSignUpPage:checked {    
	background-color: rgb(223, 223, 223);
	color: white;
}</string>
